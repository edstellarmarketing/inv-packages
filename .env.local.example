# Self-hosted Supabase configuration.
# Copy to `.env.local` and fill in real values, then restart `npm run dev`.

# Public URL of your self-hosted Supabase project (Kong / REST gateway).
# Example: https://supabase.yourcompany.com
NEXT_PUBLIC_SUPABASE_URL=

# Anon (public) API key. Safe to ship to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key. Server-side only — do NOT prefix with NEXT_PUBLIC.
# Bypasses RLS; used by API routes for invpackages writes.
SUPABASE_SERVICE_ROLE_KEY=

# Optional: direct Postgres connection. Only needed if you want to use
# the courses persistence routes that talk to the `invpackages` schema
# (custom-course CRUD). The feedback feature works via supabase-js with
# the keys above alone and does NOT require this. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME[?sslmode=disable]
DATABASE_URL=
